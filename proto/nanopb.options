# nanopb field options for the embeddable C++ codegen (device encode path).
#
# One global options file (passed to nanopb_generator with -f) instead of a
# per-proto .options next to each file — the foxglove schemas live in a git
# submodule we don't edit, so a central file is the only clean place to bound
# their fields too. Patterns are `package.Message.field` and accept `*`.
#
# Strategy:
#   - Unbounded / high-rate buffers (video / image / audio `data`, and the
#     IMU / encoder `samples` batches): left as the nanopb default pb_callback_t.
#     The producer streams straight from its existing frame buffer or sensor
#     FIFO as it encodes — zero-copy, no malloc, any size. Crucially this also
#     lets a 1 s IMU storage bundle (~200 samples) through, which a fixed array
#     could not. (No entry here = stays callback.)
#   - Small fixed-shape strings (frame_id, format tag, button id): bounded
#     inline char[N], so they need no malloc and have predictable footprint.
#   - DeviceInfo announce (rebuilt per emit, carries KB-scale serialized
#     FileDescriptorSets): FT_POINTER. Allocates only what is actually sent and
#     frees after — a fixed cap would reserve count x big-value permanently.

# ---- Vision: bounded tags, blob stays callback ----------------------------
foxglove.CompressedVideo.frame_id   max_size:32
foxglove.CompressedVideo.format     max_size:8
foxglove.CompressedImage.frame_id   max_size:32
foxglove.CompressedImage.format     max_size:8

# ---- Sensors: short button id (samples stay callback — see strategy above) -
visio_schema.v1.sensor.ButtonEvent.button_id   max_size:32

# ---- Control: command payload strings (bounded inline — small, fixed shape) -
visio_schema.v1.control.ConnectWifi.ssid              max_size:33
visio_schema.v1.control.ConnectWifi.passphrase        max_size:64
visio_schema.v1.control.SetStorage.endpoint_url       max_size:128
visio_schema.v1.control.SetStorage.region             max_size:32
visio_schema.v1.control.SetStorage.bucket             max_size:64
visio_schema.v1.control.SetStorage.access_key_id      max_size:32
visio_schema.v1.control.SetStorage.secret_access_key  max_size:64
visio_schema.v1.control.SetStorage.prefix             max_size:128
visio_schema.v1.control.TestStorage.endpoint_url      max_size:128
visio_schema.v1.control.TestStorage.region            max_size:32
visio_schema.v1.control.TestStorage.bucket            max_size:64
visio_schema.v1.control.TestStorage.access_key_id     max_size:32
visio_schema.v1.control.TestStorage.secret_access_key max_size:64
visio_schema.v1.control.TestStorage.prefix            max_size:128

# ---- Control: CommandResult ack + DeviceState snapshot (bounded inline so the
#      ack is a static struct; the two list payloads below are FT_POINTER) -----
visio_schema.v1.control.CommandResult.error_code               max_size:32
visio_schema.v1.control.CommandResult.error_message            max_size:128
visio_schema.v1.control.DeviceState.recording_session_name     max_size:64
visio_schema.v1.control.DeviceState.wifi_ssid                  max_size:33
visio_schema.v1.control.DeviceState.wifi_ip                    max_size:46
visio_schema.v1.control.DeviceState.wifi_last_error            max_size:128
visio_schema.v1.control.DeviceState.storage_endpoint           max_size:128
visio_schema.v1.control.DeviceState.storage_bucket             max_size:64
visio_schema.v1.control.DeviceState.storage_prefix             max_size:128
visio_schema.v1.control.DeviceState.upload_last_error          max_size:128

# ---- Control: variable-length result lists — FT_POINTER (mirror DeviceInfo):
#      malloc only what's sent, freed with the message; keeps CommandResult's
#      union small (a fixed array[N] would bloat every ack). -------------------
visio_schema.v1.control.WifiScanResults.results   type:FT_POINTER
visio_schema.v1.control.WifiScanResult.ssid       type:FT_POINTER
visio_schema.v1.control.WifiScanResult.security   type:FT_POINTER
visio_schema.v1.control.RecordingsList.recordings type:FT_POINTER
visio_schema.v1.control.RecordingEntry.name       type:FT_POINTER
visio_schema.v1.control.RecordingEntry.last_error type:FT_POINTER

# ---- Geometry: short frame id ---------------------------------------------
visio_schema.v1.geometry.Twist.frame_id   max_size:32

# ---- DeviceInfo discovery: a periodic announce, built fresh per emit, that
#      carries KB-scale serialized FileDescriptorSets. Everything variable-length
#      is FT_POINTER rather than callback: a device with N channels then encodes
#      by assigning N Channel structs (each with its strings + schema bytes), and
#      the receiver DECODES the same way — nanopb auto-allocates the repeated
#      Channel array and every nested string/bytes, then frees them when the
#      DeviceInfo is released. (Callbacks would force a hand-written
#      encode/decode function per field; FT_POINTER is plain struct assignment.)
#      Channel mirrors the Foxglove channel; `schema` is the FileDescriptorSet.
visio_schema.v1.service.device_info.DeviceInfo.device_name         type:FT_POINTER
visio_schema.v1.service.device_info.DeviceInfo.firmware_version    type:FT_POINTER
visio_schema.v1.service.device_info.DeviceInfo.hardware_revision   type:FT_POINTER
visio_schema.v1.service.device_info.DeviceInfo.serial              type:FT_POINTER
visio_schema.v1.service.device_info.DeviceInfo.channels            type:FT_POINTER
visio_schema.v1.service.device_info.Channel.topic                  type:FT_POINTER
visio_schema.v1.service.device_info.Channel.encoding               type:FT_POINTER
visio_schema.v1.service.device_info.Channel.schema_name            type:FT_POINTER
visio_schema.v1.service.device_info.Channel.schema_encoding        type:FT_POINTER
visio_schema.v1.service.device_info.Channel.schema                 type:FT_POINTER
