# Generated protobuf bindings — built by `make gen`, live in-package next to
# the hand-written codec. Source-only at HEAD; vendored at release tags.
# Python:
python/visio_schema/**/*_pb2.py
python/visio_schema/**/*_pb2.pyi
python/visio_schema/foxglove/
# C++ (nanopb only; no host full-protobuf C++ output):
cpp/generated_nanopb/

# buf installed locally via npm.
node_modules/
package.json
package-lock.json

# C++ build trees + Python build/test artifacts.
build/
dist/
cpp/build/
examples/cpp/build/
__pycache__/
*.egg-info/
.pytest_cache/
