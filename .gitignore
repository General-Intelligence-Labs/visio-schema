# Generated protobuf bindings — built by `make gen`, live in-package next to
# the hand-written codec. Source-only at HEAD; vendored at release tags.
# Python:
python/visio_schema/**/*_pb2.py
python/visio_schema/**/*_pb2.pyi
python/visio_schema/foxglove/
# C++ (nanopb only; no host full-protobuf C++ output):
cpp/generated_nanopb/

# buf installed locally via npm.
node_modules/
package.json
package-lock.json

# C++ build trees + Python build/test artifacts.
build/
dist/
wheelhouse/
cpp/build/
examples/cpp/build/
__pycache__/
*.egg-info/
.pytest_cache/

# Compiled native extension (_creader), built in-place by `pip install -e` /
# build_ext. Source-only at HEAD; the wheel ships the binary.
*.so
*.pyd
*.dylib

# Sibling cpp/nanopb sources vendored under python/ at build time (so setuptools
# accepts them); regenerated by _vendor_native.py from cpp/ + third_party/.
python/_native_build/
